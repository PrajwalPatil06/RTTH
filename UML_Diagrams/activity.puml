@startuml
title Activity Diagram - RAFT Transfer & Blockchain Commit Flow (Final)

skinparam linetype ortho
skinparam backgroundColor white
skinparam activity {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
}

|#F0F4FF|Client CLI|
start
:Enter transfer (receiver, amount);
:Build POST /transfer\n{clientid, payload, timestamp};
:Send to any node via Channel Proxy;

|#F0FFF0|Channel Proxy (:9000)|
:Check partition gate for target node;
if (Gate open?) then (Blocked)
    :Return 503 Unavailable;
else (Open)
    :Add 5-30ms jitter;
    :Forward to Node :808x;
end if

|#FFF8F0|RAFT Node - Handler|
:Receive POST /transfer;
:Validate ClientTransaction\n(clientID, payload, timestamp);
if (Valid?) then (No)
    :Return 400 Bad Request;
    stop
else (Yes)
end if

if (Node state?) then (Follower)
    :307 Redirect to Leader URL;
    |#F0F4FF|Client CLI|
    :Retry directly to leader;
    |#FFF8F0|RAFT Node - Handler|
else (Candidate)
    :Return 503 election in progress;
    stop
else (Leader)
end if

|#FFF0F0|Leader Node - Domain|
:Lock mutex;
:Create Transaction\n{clientID, payload, timestamp, term};
:Append to Log[];
:Persist state to disk;
:Unlock mutex, return log index;

fork
    :Send AppendEntries RPCs\nto all peers concurrently;
    |#FFFFF0|RAFT Follower Node|
    :PrevLog consistency check;
    if (Log matches?) then (No)
        :Return Success=false;
    else (Yes)
        :Append entries;
        :Advance commitIndex;
        :applyCommittedLocked();
        :Persist state;
        :Return Success=true;
    end if
    |#FFF0F0|Leader Node - Domain|
    :Update matchIndex / nextIndex;
fork again
    :WaitForCommit(index, 3s)\npoll every 50ms;
end fork

:advanceCommitIndex()\ncheck majority matchIndex;
if (Majority reached?) then (No - timeout)
    :committed = false;
else (Yes)
    :committed = true;
    :applyCommittedLocked();
    :Add txn to BlockBuffer;
    if (BlockBuffer >= 3?) then (Yes)
        :Take 3 txns as batch;
        :mine() - loop random nonces\nuntil SHA256 ends in 0/1/2;
        :BuildBlock, append to Blockchain[];
        :Persist updated chain;
    else (No)
    end if
end if

|#FFF8F0|RAFT Node - Handler|
:GetBalance(clientID);
:Return 200 OK\n{committed, committed_balance,\npending_balance};

|#F0F4FF|Client CLI|
:Display result to user;
stop

@enduml
